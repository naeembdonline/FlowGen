{
  "compilerOptions": {
    // ============================================================================
    // STRICT TYPE CHECKING (Next.js 15 Compatible - Standalone Config)
    // ============================================================================
    "strict": true,
    "noUncheckedIndexedAccess": false,
    "noImplicitReturns": true,
    "noFallthroughCasesInSwitch": true,
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "noImplicitAny": true,
    "strictNullChecks": true,
    "strictFunctionTypes": false,
    "strictBindCallApply": true,
    "strictPropertyInitialization": false,
    "alwaysStrict": true,

    // ============================================================================
    // MODULE RESOLUTION (Next.js 15 Compatible)
    // ============================================================================
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "allowImportingTsExtensions": true,
    "module": "esnext",
    "target": "ES2020",

    // ============================================================================
    // JSX CONFIGURATION
    // ============================================================================
    "jsx": "preserve",
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": true,
    "skipLibCheck": true,
    "plugins": [
      {
        "name": "next"
      }
    ],

    // ============================================================================
    // PATH ALIASES (Next.js 15 Compatible)
    // ============================================================================
    "forceConsistentCasingInFileNames": true,
    "paths": {
      "@/*": ["./src/*"],
      "@/components/*": ["./src/components/*"],
      "@/lib/*": ["./src/lib/*"],
      "@/stores/*": ["./src/stores/*"],
      "@/app/*": ["./src/app/*"],
      "@/styles/*": ["./src/styles/*"],
      "@/types/*": ["./src/types/*"],
      "@/utils/*": ["./src/utils/*"],
      "@/hooks/*": ["./src/hooks/*"]
    },

    // ============================================================================
    // INCREMENTAL COMPILATION (Next.js 15 Optimized)
    // ============================================================================
    "incremental": true,
    "noEmit": true,
    "isolatedModules": true,

    // ============================================================================
    // SOURCE MAPS & DEBUGGING
    // ============================================================================
    "sourceMap": true,
    "declarationMap": false,

    // ============================================================================
    // ADVANCED OPTIONS
    // ============================================================================
    "skipDefaultLibCheck": true
  },

  // ============================================================================
  // INCLUDE FILES (Next.js 15 Optimized)
  // ============================================================================
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts",
    "src/**/*.ts",
    "src/**/*.tsx"
  ],

  // ============================================================================
  // EXCLUDE FILES
  // ============================================================================
  "exclude": [
    "node_modules",
    ".next",
    "dist",
    "build"
  ]
}