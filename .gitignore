# ============================================================================
# FLOWGEN LEAD GENERATION SAAS - GITIGNORE
# ============================================================================
# This file ensures sensitive files and build artifacts are not committed
# ============================================================================

# ============================================================================
# DEPENDENCIES
# ============================================================================
node_modules/
.pnp
.pnp.js

# ============================================================================
# ENVIRONMENT FILES (NEVER COMMIT THESE!)
# ============================================================================
.env
.env.local
.env.*.local
!.env.example

# ============================================================================
# PRODUCTION BUILDS
# ============================================================================
dist/
build/
.next/
out/

# ============================================================================
# LOGGING & DEBUGGING
# ============================================================================
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# ============================================================================
# TESTING & COVERAGE
# ============================================================================
coverage/
.nyc_output/

# ============================================================================
# IDE & EDITORS
# ============================================================================
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store

# ============================================================================
# DATABASES
# ============================================================================
*.db
*.sqlite
*.sqlite3

# ============================================================================
# DOCKER
# ============================================================================
docker-compose.override.yml

# ============================================================================
# TEMPORARY FILES
# ============================================================================
tmp/
temp/
*.tgz
*.local

# ============================================================================
# FLOWGEN SPECIFIC
# ============================================================================
# Claude Code memory and plans
.claude/memory/
.claude/plans/

# Session transcripts and temp files
*.transcript/
.claude/tmp/

# Redis data (if running locally)
redis-data/
dump.rdb

# Supabase local data (if any)
.supabase/

# ============================================================================
# OS GENERATED FILES
# ============================================================================
Thumbs.db
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db

# ============================================================================
