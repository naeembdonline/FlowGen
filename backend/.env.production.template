# ============================================================================
# FIKERFLOW LEAD GENERATION SAAS - PRODUCTION ENVIRONMENT VARIABLES
# ============================================================================
# Copy this file to .env and fill in your actual values
# Command: cp .env.production.template .env
# ============================================================================

# ============================================================================
# SUPABASE CONFIGURATION (REQUIRED)
# ============================================================================
# Get these from your Supabase project dashboard: https://supabase.com/dashboard
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.your-service-role-key-here

# ============================================================================
# AI API KEYS (REQUIRED)
# ============================================================================
# Z.ai API for AI message generation
# Get your API key from: https://z.ai/dashboard
Z_AI_API_KEY=your-z-ai-api-key-here

# OpenAI API for alternative AI generation
# Get your API key from: https://platform.openai.com/api-keys
OPENAI_API_KEY=your-openai-api-key-here

# ============================================================================
# JWT CONFIGURATION (REQUIRED)
# ============================================================================
# Secret key for JWT token verification
# Generate with: openssl rand -base64 32
JWT_SECRET=your-jwt-secret-key-minimum-32-characters-long

# ============================================================================
# REDIS CONFIGURATION (FOR DOCKER PRODUCTION)
# ============================================================================
# These are pre-configured for Docker Compose production setup
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_URL=redis://redis:6379

# ============================================================================
# APPLICATION SETTINGS
# ============================================================================
NODE_ENV=production
PORT=3001
FRONTEND_URL=https://leads.naeemmia.bd

# Cache Configuration
# Set to 'true' to force in-memory cache (ignore Redis)
# Set to 'false' to use Redis cache (recommended for production)
USE_IN_MEMORY_CACHE=false

# ============================================================================
# OPTIONAL: GOOGLE MAPS SCRAPING
# ============================================================================
# If using a third-party Google Maps scraping service
# OMKARCLOUD_API_KEY=your-omkarcloud-api-key-here

# ============================================================================
# OPTIONAL: WHATSAPP MESSAGING (Evolution API)
# ============================================================================
# Get credentials from: https://doc.evolution-api.com
# EVOLUTION_API_URL=https://your-evolution-instance.com
# EVOLUTION_API_KEY=your-evolution-api-key-here

# ============================================================================
# OPTIONAL: EMAIL MARKETING (Brevo)
# ============================================================================
# Get credentials from: https://brevo.com
# BREVO_API_KEY=your-brevo-api-key-here
# BREVO_SENDER_EMAIL=noreply@fikerflow.com
# BREVO_SENDER_NAME=FikerFlow Leads

# ============================================================================
# OPTIONAL: STRIPE PAYMENT PROCESSING
# ============================================================================
# Get credentials from: https://stripe.com/dashboard
# STRIPE_SECRET_KEY=sk_test_your-stripe-secret-key
# STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret
# STRIPE_PRICE_ID_PRO=price_your-pro-plan-price-id
# STRIPE_PRICE_ID_ENTERPRISE=price_your-enterprise-price-id

# ============================================================================
# OPTIONAL: LOGGING & MONITORING
# ============================================================================
# LOG_LEVEL=info
# SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id

# ============================================================================
# OPTIONAL: RATE LIMITING
# ============================================================================
# RATE_LIMIT_WINDOW_MS=900000
# RATE_LIMIT_MAX_REQUESTS=100

# ============================================================================
# PRODUCTION NOTES
# ============================================================================
#
# SECURITY REMINDERS:
# 1. Never commit .env file to version control
# 2. Use strong, unique secrets for JWT and API keys
# 3. Rotate secrets periodically
# 4. Use read-only database credentials when possible
# 5. Enable SSL/TLS for all external connections
#
# CONFIGURATION STEPS:
# 1. Copy this file: cp .env.production.template .env
# 2. Fill in all required values (marked as REQUIRED above)
# 3. Run: chmod 600 .env (restrict file permissions)
# 4. Test environment loading: node test-env.js
# 5. Verify all services connect: npm run health-check
#
# TROUBLESHOOTING:
# - If Supabase connection fails: Check SUPABASE_URL and keys
# - If Redis connection fails: Check Redis container is running
# - If AI generation fails: Verify API keys are valid
# - For environment issues: Run node test-env.js for debugging
#
# ============================================================================
# END OF PRODUCTION ENVIRONMENT VARIABLES
# ============================================================================