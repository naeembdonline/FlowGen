# ============================================================================
# FLOWGEN LEAD GENERATION SAAS - ENVIRONMENT VARIABLES
# ============================================================================
# Copy this file to .env and fill in the actual values
# DO NOT commit .env to git (it's already in .gitignore)
# ============================================================================

# ----------------------------------------------------------------------------
# SUPABASE (Database + Authentication)
# ----------------------------------------------------------------------------
# Get these from: https://supabase.com -> Your Project -> Settings -> API
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Explanation:
# - SUPABASE_URL: Your Supabase project URL (format: https://xyz.supabase.co)
# - SUPABASE_ANON_KEY: Public key for client-side requests (safe to expose)
# - SUPABASE_SERVICE_ROLE_KEY: Admin key (NEVER expose to frontend, backend only)

# ----------------------------------------------------------------------------
# ANTHROPIC CLAUDE AI (Message Generation)
# ----------------------------------------------------------------------------
# Get from: https://console.anthropic.com -> API Keys
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Explanation:
# Used for AI-powered personalized message generation
# Pricing: https://www.anthropic.com/pricing
# Free tier available for testing

# ----------------------------------------------------------------------------
# OMKARCLOUD (Google Maps Scraping)
# ----------------------------------------------------------------------------
# Get from: https://omkarcloud.com (sign up and get API key)
OMKARCLOUD_API_KEY=your-omkarcloud-key-here

# Explanation:
# Scrapes business data from Google Maps
# Search by: location, category, keywords
# Returns: business name, phone, email, website, address, reviews

# ----------------------------------------------------------------------------
# EVOLUTION API (WhatsApp Messaging)
# ----------------------------------------------------------------------------
# Get from: https://doc.evolution-api.com
# You'll need to deploy an instance or use their cloud service
EVOLUTION_API_URL=https://your-instance.evolution-api.com
EVOLUTION_API_KEY=your-evolution-key-here
EVOLUTION_INSTANCE_NAME=fikerflow-instance

# Explanation:
# Sends WhatsApp messages programmatically
# Requires: WhatsApp Business API access
# Features: Send messages, receive webhooks, track delivery

# ----------------------------------------------------------------------------
# BREVO (Email Marketing)
# ----------------------------------------------------------------------------
# Get from: https://brevo.com -> Account -> SMTP & API
BREVO_API_KEY=xkeysib-your-key-here
BREVO_SENDER_EMAIL=noreply@yourdomain.com
BREVO_SENDER_NAME=Fikerflow

# Explanation:
# Transactional email service (formerly Sendinblue)
# Free tier: 300 emails/day
# Features: Email sending, templates, analytics

# ----------------------------------------------------------------------------
# REDIS (Job Queue & Caching)
# ----------------------------------------------------------------------------
# For local development, use Docker Compose (starts Redis on port 6379)
# For production, use Redis Cloud or AWS ElastiCache
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=

# Explanation:
# Job queue (Bull) for async message processing
# Caching layer for API responses
# Session storage (optional)

# ----------------------------------------------------------------------------
# STRIPE (Payment Processing)
# ----------------------------------------------------------------------------
# Get from: https://dashboard.stripe.com -> Developers -> API keys
# Only needed for Phase 6 (SaaS features)
STRIPE_SECRET_KEY=sk_test_your-key-here
STRIPE_PUBLISHABLE_KEY=pk_test_your-key-here
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret-here
STRIPE_PRICE_ID_PRO=price_your-pro-plan-id
STRIPE_PRICE_ID_ENTERPRISE=price_your-enterprise-id

# Explanation:
# Handles subscription billing
# Test mode keys for development
# Production keys needed before launch

# ----------------------------------------------------------------------------
# APPLICATION SETTINGS
# ----------------------------------------------------------------------------
NODE_ENV=development
PORT=3001
FRONTEND_URL=http://localhost:3000

# Explanation:
# - NODE_ENV: development | production | test
# - PORT: Backend API server port
# - FRONTEND_URL: Frontend URL for CORS configuration

# ----------------------------------------------------------------------------
# JWT CONFIGURATION
# ----------------------------------------------------------------------------
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRES_IN=7d

# Explanation:
# - JWT_SECRET: Secret key for signing JWT tokens (use strong random string)
# - JWT_EXPIRES_IN: Token expiration (7d = 7 days)

# ----------------------------------------------------------------------------
# RATE LIMITING
# ----------------------------------------------------------------------------
# Prevents API abuse and manages external service rate limits
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# WhatsApp rate limits (Evolution API)
WHATSAPP_RATE_LIMIT_PER_MINUTE=60

# Email rate limits (Brevo)
EMAIL_RATE_LIMIT_PER_MINUTE=300

# Explanation:
# - RATE_LIMIT_WINDOW_MS: Time window in milliseconds (15 min = 900000ms)
# - RATE_LIMIT_MAX_REQUESTS: Max requests per window
# - Service-specific limits to prevent API blocking

# ----------------------------------------------------------------------------
# AWS S3 (File Storage - Optional)
# ----------------------------------------------------------------------------
# Used for storing attachments, exports, etc.
# Skip if not using file storage features
AWS_ACCESS_KEY_ID=your-access-key
AWS_SECRET_ACCESS_KEY=your-secret-key
AWS_REGION=us-east-1
AWS_S3_BUCKET=fikerflow-uploads

# ----------------------------------------------------------------------------
# LOGGING & MONITORING
# ----------------------------------------------------------------------------
# Enable detailed logging in development
LOG_LEVEL=debug

# Sentry (Error tracking - optional)
SENTRY_DSN=
SENTRY_ENVIRONMENT=development

# ----------------------------------------------------------------------------
# FEATURE FLAGS
# ----------------------------------------------------------------------------
# Enable/disable features without deploying code
FEATURE_WHATSAPP_ENABLED=true
FEATURE_EMAIL_ENABLED=true
FEATURE_AI_GENERATION_ENABLED=true
FEATURE_ANALYTICS_ENABLED=true
FEATURE_BILLING_ENABLED=false  # Set to true in Phase 6

# ----------------------------------------------------------------------------
# DEVELOPMENT SETTINGS
# ----------------------------------------------------------------------------
# Enable hot reload, debug mode, etc.
DEBUG=true
HOT_RELOAD=true

# ----------------------------------------------------------------------------
# MIGRATION & SEEDING
# ----------------------------------------------------------------------------
# Database migration settings
AUTO_MIGRATE=true
SEED_DEMO_DATA=false

# ============================================================================
# SETUP INSTRUCTIONS
# ============================================================================
#
# 1. Copy this file: cp .env.example .env
# 2. Fill in each value with your actual API keys and configuration
# 3. NEVER commit .env to git (already in .gitignore)
# 4. Keep .env.example updated when adding new environment variables
#
# ============================================================================
